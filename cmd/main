#!/bin/sh
set -eu

pid_file="${TRIM_PKGVAR:?}/netbird-fnos-api.pid"
socket_path="${TRIM_APPDEST:?}/app.sock"
log_file="${TRIM_PKGVAR}/netbird-fnos-api.log"
daemon_dir="${TRIM_PKGVAR}/netbird"
daemon_pid_file="${daemon_dir}/daemon.pid"
daemon_socket="${daemon_dir}/daemon.sock"
daemon_log="${daemon_dir}/daemon.log"
daemon_config="${daemon_dir}/config.json"

write_error() { printf '%s\n' "$1" > "${TRIM_TEMP_LOGFILE:-/dev/stderr}"; }
is_running() {
  [ -f "$pid_file" ] || return 1
  pid="$(cat "$pid_file")"
  kill -0 "$pid" 2>/dev/null
}
daemon_running() {
  [ -f "$daemon_pid_file" ] || return 1
  daemon_pid="$(cat "$daemon_pid_file")"
  kill -0 "$daemon_pid" 2>/dev/null
}
start_daemon() {
  if daemon_running; then return 0; fi
  mkdir -p "$daemon_dir"
  rm -f "$daemon_pid_file" "$daemon_socket"
  NB_STATE_DIR="$daemon_dir" nohup "${TRIM_APPDEST}/bin/netbird" --daemon-addr "unix://${daemon_socket}" --config "$daemon_config" --log-file "$daemon_log" service run >/dev/null 2>&1 &
  echo "$!" > "$daemon_pid_file"
  sleep 1
  daemon_running
}
stop_daemon() {
  if daemon_running; then
    daemon_pid="$(cat "$daemon_pid_file")"
    kill "$daemon_pid" 2>/dev/null || true
  fi
  rm -f "$daemon_pid_file" "$daemon_socket"
}
case "${1:-}" in
  start)
    if is_running; then exit 0; fi
    rm -f "$pid_file" "$socket_path"
    if ! start_daemon; then write_error "NetBird daemon failed to start; inspect $daemon_log."; exit 1; fi
    export NB_FNOS_SOCKET="$socket_path" NB_FNOS_DAEMON_ADDR="unix://${daemon_socket}" NB_STATE_DIR="$daemon_dir" NB_FNOS_GATEWAY_PREFIX="/app/netbird-fnos" NB_FNOS_WEB_ROOT="${TRIM_APPDEST}/www"
    nohup "${TRIM_APPDEST}/bin/netbird-fnos-api" >>"$log_file" 2>&1 &
    echo "$!" > "$pid_file"
    sleep 1
    if ! is_running; then write_error "NetBird service failed to start; inspect $log_file."; exit 1; fi
    ;;
  stop)
    if ! is_running; then rm -f "$pid_file" "$socket_path"; stop_daemon; exit 0; fi
    pid="$(cat "$pid_file")"
    kill "$pid"
    attempts=0
    while is_running && [ "$attempts" -lt 10 ]; do sleep 1; attempts=$((attempts + 1)); done
    if is_running; then write_error "NetBird service did not stop."; exit 1; fi
    rm -f "$pid_file" "$socket_path"
    stop_daemon
    ;;
  status) if is_running; then exit 0; fi; exit 3 ;;
  *) write_error "Unsupported lifecycle action: ${1:-empty}"; exit 1 ;;
esac
